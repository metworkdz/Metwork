# ─────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Metwork
NEXT_PUBLIC_DEFAULT_LOCALE=en

# ─────────────────────────────────────────────
# API (NestJS backend — to be deployed separately)
# ─────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
API_INTERNAL_URL=http://api:4000

# ─────────────────────────────────────────────
# Database (Postgres)
# ─────────────────────────────────────────────
DATABASE_URL="postgresql://metwork:metwork@localhost:5432/metwork?schema=public"

# ─────────────────────────────────────────────
# Auth
# ─────────────────────────────────────────────
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_COOKIE_NAME=metwork_session
AUTH_COOKIE_DOMAIN=localhost

# ─────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────────
# File storage (MinIO / S3-compatible)
# ─────────────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=metwork-uploads
S3_PUBLIC_URL=http://localhost:9000/metwork-uploads

# ─────────────────────────────────────────────
# Notifications
# ─────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM="Metwork <noreply@metwork.dz>"
SMS_PROVIDER=mock
SMS_API_KEY=
SMS_SENDER_ID=METWORK

# ─────────────────────────────────────────────
# Payment provider (abstracted via PaymentProvider interface)
#   mock     — local-only, settles synchronously; flip to async via
#              MOCK_PAYMENT_MODE=async to exercise the webhook path
#   slickpay — Algerian processor (CIB / Edahabia hosted checkout)
#   cib / edahabia — direct integrations (not implemented yet)
# ─────────────────────────────────────────────
PAYMENT_PROVIDER=mock
PAYMENT_WEBHOOK_SECRET=
MOCK_PAYMENT_MODE=sync

# SlickPay — required when PAYMENT_PROVIDER=slickpay
SLICKPAY_PUBLIC_KEY=
SLICKPAY_SECRET_KEY=
SLICKPAY_WEBHOOK_SECRET=
SLICKPAY_API_BASE=https://prod.slick-pay.com/api/v2

# ─────────────────────────────────────────────
# Observability
# ─────────────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
